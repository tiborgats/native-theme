---
config:
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 42
    rankSpacing: 65
    padding: 14
  themeVariables:
    fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif'
    fontSize: 14px
---
flowchart LR
    App(["<b>Your Rust app</b>"])

    subgraph Connectors["&nbsp;&nbsp;pick one connector&nbsp;&nbsp;"]
        direction TB
        NTG("<code><b>native-theme-gpui</b></code><br/><span style='color:#64748b;font-size:12px'>GPUI connector</span>")
        NTI("<code><b>native-theme-iced</b></code><br/><span style='color:#64748b;font-size:12px'>iced connector</span>")
    end

    NTB("<code><b>native-theme-build</b></code><br/><span style='color:#64748b;font-size:12px'>custom icon codegen<br/>optional · build.rs</span>")
    NT("<code><b>native-theme</b></code><br/><span style='color:#64748b;font-size:12px'>runtime core<br/>Theme · ResolvedTheme · presets</span>")
    NTD("<code><b>native-theme-derive</b></code><br/><span style='color:#64748b;font-size:12px'>proc-macro<br/>(internal)</span>")

    App -->|"&nbsp;depends on&nbsp;"| Connectors
    App -.->|"&nbsp;optional&nbsp;"| NTB
    NTG --> NT
    NTI --> NT
    NT -.->|"&nbsp;proc-macro&nbsp;"| NTD

    classDef app fill:#eff6ff,stroke:#2563eb,stroke-width:2px,color:#1e3a8a
    classDef runtime fill:#f0f9ff,stroke:#0284c7,stroke-width:2px,color:#0c4a6e
    classDef connector fill:#ecfdf5,stroke:#059669,stroke-width:2px,color:#064e3b
    classDef optional fill:#fffbeb,stroke:#d97706,stroke-width:2px,color:#78350f
    classDef internal fill:#f3f4f6,stroke:#9ca3af,stroke-dasharray:5 3,stroke-width:2px,color:#4b5563
    classDef connectorGroup fill:#f0fdf4,stroke:#10b981,stroke-width:2px,stroke-dasharray:6 4,color:#065f46,rx:14,ry:14

    class App app
    class NT runtime
    class NTG,NTI connector
    class NTB optional
    class NTD internal
    class Connectors connectorGroup

    linkStyle default stroke:#64748b,stroke-width:2px
